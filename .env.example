# Scheduler (cron expression para el envío periódico de licitaciones)
# Default si no se define: 0 0 6 * * MON-FRI (Lunes a viernes a las 8:00 de la mañana)
# Ejemplos:
#   0 0 8 * * *       → todos los días a las 08:00
#   0 0 8 * * MON-FRI → lunes a viernes a las 08:00
#   0 0 */6 * * *     → cada 6 horas
SCHEDULER_CRON=0 * * * * *

